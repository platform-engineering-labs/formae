amends "@formae/forma.pkl"
import "@formae/formae.pkl"

// Resource imports
import "@aws/cloudfront/distribution.pkl"

forma {
    
local myStack = new formae.Stack {
  // Please provide a stack to bring the resources in this Forma under management
label = "test"
  description = "This was generated"
}
myStack

    
local usWest1 = new formae.Target {
  label = "us-west-1"
  namespace = "AWS"
  config {
      Region = "us-west-1"
      Type = "AWS"
    }
}
usWest1

    new distribution.Distribution {
    label = "ASDF1234ASF"
    distributionConfig = new distribution.DistributionConfig {
      aliases = new Listing { "www.test.pel"; "test.pel" }
      comment = ""
      continuousDeploymentPolicyId = ""
      defaultCacheBehavior = new distribution.DefaultCacheBehavior {
        allowedMethods = new Listing { "HEAD"; "GET" }
        cachePolicyId = "12345ab-a12a-1234-1234-asfdojui324"
        cachedMethods = new Listing { "HEAD"; "GET" }
        compress = true
        fieldLevelEncryptionId = ""
        grpcConfig = new distribution.GrpcConfig {
          enabled = false
        }
        smoothStreaming = false
        targetOriginId = "testtadsfasdf"
        viewerProtocolPolicy = "allow-all"
      }
      defaultRootObject = ""
      enabled = true
      httpVersion = "http2"
      ipV6Enabled = true
      logging = new distribution.Logging {
        bucket = ""
        includeCookies = false
        prefix = ""
      }
      originGroups = new distribution.OriginGroups {
        quantity = 0
      }
      origins = new Listing { new distribution.Origin {
        connectionAttempts = 3
        connectionTimeout = 10
        customOriginConfig = new distribution.CustomOriginConfig {
          httpPort = 80
          httpsPort = 443
          originKeepaliveTimeout = 5
          originProtocolPolicy = "http-only"
          originReadTimeout = 30
          originSSLProtocols = new Listing { "TLSv1.2" }
        }
        domainName = "test.pel.s3-website-us-east-1.amazonaws.com"
        id = "landingpage"
        originAccessControlId = ""
        originPath = ""
        originShield = new distribution.OriginShield {
          enabled = false
        }
      } }
      priceClass = "PriceClass_All"
      restrictions = new distribution.Restrictions {
        geoRestriction = new distribution.GeoRestriction {
          restrictionType = "none"
        }
      }
      staging = false
      viewerCertificate = new distribution.ViewerCertificate {
        acmCertificateArn = "arn:aws:acm:us-east-1:123456789:certificate/1234555-12a3-1234a-1234s-1234565as"
        cloudFrontDefaultCertificate = false
        minimumProtocolVersion = "TLSv1.2_2021"
        sslSupportMethod = "sni-only"
      }
      webACLId = ""
    }
    target = usWest1.res
    stack = myStack.res
  }
}