amends "@formae/forma.pkl"
import "@formae/formae.pkl"

// Resource imports
import "@aws/iam/group.pkl"

forma {
    
local myStack = new formae.Stack {
  // Please provide a stack to bring the resources in this Forma under management
label = "test"
  description = "This was generated"
}
myStack

    
local usWest2 = new formae.Target {
  label = "us-west-2"
  namespace = "AWS"
  config {
      Region = "us-west-2"
      Type = "AWS"
    }
}
usWest2

    new group.Group {
    label = "dev"
    groupName = "dev"
    managedPolicyArns = new Listing { "arn:aws:iam::aws:policy/AdministratorAccess" }
    path = "/"
    target = usWest2.res
    stack = myStack.res
  }
}