amends "@formae/forma.pkl"
import "@formae/formae.pkl"

// Resource imports
import "@aws/rds/dbparametergroup.pkl"

forma {
    
local myStack = new formae.Stack {
  // Please provide a stack to bring the resources in this Forma under management
label = "test"
  description = "This was generated"
}
myStack

    
local usWest2 = new formae.Target {
  label = "us-west-2"
  namespace = "AWS"
  config {
      Region = "us-west-2"
      Type = "AWS"
    }
}
usWest2

    new dbparametergroup.DBParameterGroup {
    label = "default.postgres13"
    dbParameterGroupName = "default.postgres13"
    description = "Default parameter group for postgres13"
    family = "postgres13"
    parameters = new Dynamic {

    }
    target = usWest2.res
    stack = myStack.res
  }
}