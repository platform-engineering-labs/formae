amends "@formae/forma.pkl"
import "@formae/formae.pkl"

// Resource imports
import "@aws/ecs/ecscluster.pkl"
// Dependency imports
import "@aws/aws.pkl"

forma {
    
local ecsHelloWorld = new formae.Stack {
          label = "ecs-hello-world"
  description = "This was generated"
}
ecsHelloWorld

    
local defaultAwsTarget = new formae.Target {
  label = "default-aws-target"
  namespace = "AWS"
  config {
      Type = "AWS"
      Region = "eu-central-1"
    }
}
defaultAwsTarget

    new ecscluster.Cluster {
    label = "ecs-hello-cluster2"
    capacityProviders = new Listing {  }
    clusterName = "ecs-hello-world-cluster2"
    clusterSettings = new Listing { new ecscluster.ClusterClusterSettings {
      name = "containerInsights"
      value = "disabled"
    } }
    defaultCapacityProviderStrategy = new Listing {  }
    tags = new Listing<aws.Tag> { new aws.Tag {
      key = "Name"
      value = "ecs-hello-world-cluster"
    } }
    target = defaultAwsTarget.res
    stack = ecsHelloWorld.res
  }

new ecscluster.Cluster {
    label = "ecs-hello-world-cluster"
    capacityProviders = new Listing {  }
    clusterName = "ecs-hello-world-cluster"
    clusterSettings = new Listing { new ecscluster.ClusterClusterSettings {
      name = "containerInsights"
      value = "disabled"
    } }
    defaultCapacityProviderStrategy = new Listing {  }
    tags = new Listing<aws.Tag> { new aws.Tag {
      key = "Name"
      value = "ecs-hello-world-cluster"
    } }
    target = defaultAwsTarget.res
    stack = ecsHelloWorld.res
  }
}