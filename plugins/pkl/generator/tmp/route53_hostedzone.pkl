amends "@formae/forma.pkl"
import "@formae/formae.pkl"

// Resource imports
import "@aws/route53/hostedzone.pkl"

forma {
    
local myStack = new formae.Stack {
  // Please provide a stack to bring the resources in this Forma under management
label = "test"
  description = "This was generated"
}
myStack

    
local usWest1 = new formae.Target {
  label = "us-west-1"
  namespace = "AWS"
  config {
      Region = "us-west-1"
      Type = "AWS"
    }
}
usWest1

    new hostedzone.HostedZone {
    label = "Z01234567890ABCDEF"
    hostedZoneConfig = new hostedzone.HostedZoneConfig {
      comment = "HostedZone created by Route53 Registrar"
    }
    name = "example.com."
    vpcs = new Listing {  }
    target = usWest1.res
    stack = myStack.res
  }

new hostedzone.HostedZone {
    label = "Z01762211CHP02OT2BGCB"
    hostedZoneConfig = new hostedzone.HostedZoneConfig {
      comment = "HostedZone created by Route53 Registrar"
    }
    name = "test.platformengineering.local."
    vpcs = new Listing { new hostedzone.VPC {
      vpcId = "vpc-123456789"
      vpcRegion = "us-west-1"
    } }
    target = usWest1.res
    stack = myStack.res
  }
}