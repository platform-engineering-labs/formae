    dbParameterGroupName = "default.postgres13"
    dbSubnetGroupName = new dbsubnetgroup.DBSubnetGroupResolvable {
      // RealValue: secret-resolution-db-subnet-group
      stack = secretResolution.res.label
      label = "DBSubnetGroup"
    }.dbSubnetGroupName
    dedicatedLogVolume = false
    deletionProtection = false
    enableCloudwatchLogsExports = new Listing {  }
    enableIAMDatabaseAuthentication = false
    enablePerformanceInsights = false
    endpoint = new dbinstance.Endpoint {
