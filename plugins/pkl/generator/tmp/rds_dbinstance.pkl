      hostedZoneId = "Z1PVIF0B656C1W"
      port = "5432"
    }
    engine = "postgres"
    engineLifecycleSupport = "open-source-rds-extended-support"
    engineVersion = "13.20"
    kmsKeyId = "arn:aws:kms:us-west-2:021891619792:key/d18124f0-c4bf-4b7e-8e20-8c574916f009"
    licenseModel = "postgresql-license"
    manageMasterUserPassword = false
    masterUserPassword = new secret.SecretResolvable {
      // RealValue: 47efbe0559f4c486c94b7c0b4594caf099a8dd061ec4dbad708006025f537f89
      stack = secretResolution.res.label
      label = "DBSecret"
    }.secretString
    masterUserSecret = new dbinstance.MasterUserSecret {

    }
    masterUsername = "testuser"
    monitoringInterval = 0
