amends "@formae/forma.pkl"
import "@formae/formae.pkl"

// Resource imports
import "@aws/rds/dbinstance.pkl"
// Dependency imports
import "@aws/rds/dbsubnetgroup.pkl"
import "@aws/secretsmanager/secret.pkl"
import "@aws/aws.pkl"

forma {
    
local secretResolution = new formae.Stack {
          label = "secret-resolution"
  description = "This was generated"
}
secretResolution

    
local awsTarget = new formae.Target {
  label = "aws-target"
  namespace = "AWS"
  config {
      Type = "AWS"
      Region = "us-west-2"
    }
}
awsTarget

    new dbinstance.DBInstance {
    label = "Database"
    allocatedStorage = 20
    associatedRoles = new Listing {  }
    autoMinorVersionUpgrade = true
    availabilityZone = "us-west-2a"
