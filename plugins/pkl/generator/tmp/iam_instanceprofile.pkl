amends "@formae/forma.pkl"
import "@formae/formae.pkl"

// Resource imports
import "@aws/iam/instanceprofile.pkl"

forma {
    
local myStack = new formae.Stack {
  // Please provide a stack to bring the resources in this Forma under management
label = "test"
  description = "This was generated"
}
myStack

    
local usWest2 = new formae.Target {
  label = "us-west-2"
  namespace = "AWS"
  config {
      Region = "us-west-2"
      Type = "AWS"
    }
}
usWest2

    new instanceprofile.InstanceProfile {
    label = "eks-us-west-2-eks-example-14903859267279293829"
    instanceProfileName = "eks-us-west-2-eks-example-14903859267279293829"
    path = "/"
    roles = new Listing {  }
    target = usWest2.res
    stack = myStack.res
  }
}