amends "@formae/forma.pkl"
import "@formae/formae.pkl"

// Resource imports
import "@aws/iam/oidcprovider.pkl"
// Dependency imports
import "@aws/aws.pkl"

forma {
    
local myStack = new formae.Stack {
  // Please provide a stack to bring the resources in this Forma under management
label = "test"
  description = "This was generated"
}
myStack

    
local usWest1 = new formae.Target {
  label = "us-west-1"
  namespace = "AWS"
  config {
      Region = "us-west-1"
      Type = "AWS"
    }
}
usWest1

    new oidcprovider.OIDCProvider {
    label = "example-eks-irsa"
    clientIdList = new Listing { "sts.amazonaws.com" }
    tags = new Listing<aws.Tag> { new aws.Tag {
      key = "Terraform"
      value = "true"
    }; new aws.Tag {
      key = "Environment"
      value = "development"
    }; new aws.Tag {
      key = "Name"
      value = "example-eks-irsa"
    } }
    thumbprintList = new Listing { "12345678901234567890123456789012345678ab" }
    url = "https://oidc.eks.us-west-1.amazonaws.com/id/ABCDEF1234567890ABCDEF1234567890"
    target = usWest1.res
    stack = myStack.res
  }
}