amends "@formae/forma.pkl"
import "@formae/formae.pkl"

// Resource imports
import "@aws/secretsmanager/secret.pkl"
// Dependency imports
import "@aws/aws.pkl"

forma {
    
local secretResolution = new formae.Stack {
          label = "secret-resolution"
  description = "This was generated"
}
secretResolution

    
local awsTarget = new formae.Target {
  label = "aws-target"
  namespace = "AWS"
  config {
      Type = "AWS"
      Region = "us-west-2"
    }
}
awsTarget

    new secret.Secret {
    label = "DBSecret"
    description = "Database password secret (randomly generated)"
    name = "secret-resolution-password"
    replicaRegions = new Listing {  }
    secretString = new formae.Value {
      // Value: ***HIDDEN***
      value = "47efbe0559f4c486c94b7c0b4594caf099a8dd061ec4dbad708006025f537f89"
      visibility = "Opaque"
      strategy = "SetOnce"
    }
    target = awsTarget.res
    stack = secretResolution.res
  }
}