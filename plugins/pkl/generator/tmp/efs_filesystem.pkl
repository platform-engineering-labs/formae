amends "@formae/forma.pkl"
import "@formae/formae.pkl"

// Resource imports
import "@aws/efs/filesystem.pkl"
// Dependency imports
import "@aws/aws.pkl"

forma {
    
local myStack = new formae.Stack {
  // Please provide a stack to bring the resources in this Forma under management
label = "test"
  description = "This was generated"
}
myStack

    
local usWest2 = new formae.Target {
  label = "us-west-2"
  namespace = "AWS"
  config {
      Region = "us-west-2"
      Type = "AWS"
    }
}
usWest2

    new filesystem.FileSystem {
    label = "fs-0b7a3b44276e507f0"
    backupPolicy = new filesystem.BackupPolicy {
      status = "DISABLED"
    }
    encrypted = true
    fileSystemProtection = new filesystem.FileSystemProtection {
      replicationOverwriteProtection = "ENABLED"
    }
    fileSystemTags = new Listing { new aws.Tag {
      key = "ManagedByAmazonSageMakerResource"
      value = "arn:aws:sagemaker:us-west-2:021891619792:domain/d-qwd24yu2fxfm"
    } }
    kmsKeyId = "arn:aws:kms:us-west-2:021891619792:key/56b7cac7-091e-4cde-a9e6-eeb875c90bf0"
    lifecyclePolicies = new Listing {  }
    performanceMode = "generalPurpose"
    throughputMode = "bursting"
    target = usWest2.res
    stack = myStack.res
  }
}