amends "@formae/forma.pkl"
import "@formae/formae.pkl"

// Resource imports
import "@aws/elasticloadbalancingv2/listener.pkl"
// Dependency imports
import "@aws/elasticloadbalancingv2/loadbalancer.pkl"

forma {
    
local ecsHelloWorld = new formae.Stack {
          label = "ecs-hello-world"
  description = "This was generated"
}
ecsHelloWorld

    
local defaultAwsTarget = new formae.Target {
  label = "default-aws-target"
  namespace = "AWS"
  config {
      Type = "AWS"
      Region = "eu-central-1"
    }
}
defaultAwsTarget

    new listener.Listener {
    label = "ecs-listener"
    defaultActions = new Listing { new listener.Action {
      forwardConfig = new listener.ForwardConfig {
        targetGroupStickinessConfig = new listener.TargetGroupStickinessConfig {
          enabled = false
        }
        targetGroups = new Listing { new listener.TargetGroupTuple {
          targetGroupArn = "arn:aws:elasticloadbalancing:eu-central-1:021891619792:targetgroup/ecs-hello-world-tg/709eae7a449d064c"
          weight = 1
        } }
      }
      targetGroupArn = "arn:aws:elasticloadbalancing:eu-central-1:021891619792:targetgroup/ecs-hello-world-tg/709eae7a449d064c"
      type = "forward"
    } }
    listenerAttributes = new Listing { new listener.ListenerAttribute {
      key = "routing.http.response.server.enabled"
      value = "true"
    }; new listener.ListenerAttribute {
      key = "routing.http.response.access_control_allow_headers.header_value"
      value = ""
    }; new listener.ListenerAttribute {
      key = "routing.http.response.x_frame_options.header_value"
      value = ""
    }; new listener.ListenerAttribute {
      key = "routing.http.response.access_control_allow_methods.header_value"
      value = ""
    }; new listener.ListenerAttribute {
      key = "routing.http.response.access_control_allow_origin.header_value"
      value = ""
    }; new listener.ListenerAttribute {
      key = "routing.http.response.access_control_allow_credentials.header_value"
      value = ""
    }; new listener.ListenerAttribute {
      key = "routing.http.response.x_content_type_options.header_value"
      value = ""
    }; new listener.ListenerAttribute {
      key = "routing.http.response.content_security_policy.header_value"
      value = ""
    }; new listener.ListenerAttribute {
      key = "routing.http.response.access_control_expose_headers.header_value"
      value = ""
    }; new listener.ListenerAttribute {
      key = "routing.http.response.strict_transport_security.header_value"
      value = ""
    }; new listener.ListenerAttribute {
      key = "routing.http.response.access_control_max_age.header_value"
      value = ""
    } }
    loadBalancerArn = new loadbalancer.LoadBalancerResolvable {
      // RealValue: arn:aws:elasticloadbalancing:eu-central-1:021891619792:loadbalancer/app/ecs-hello-world-alb/ddd4c593d7b2613a
      stack = ecsHelloWorld.res.label
      label = "ecs-alb"
    }.loadBalancerArn
    port = 80
    protocol = "HTTP"
    target = defaultAwsTarget.res
    stack = ecsHelloWorld.res
  }
}