amends "@formae/forma.pkl"
import "@formae/formae.pkl"

// Resource imports
import "@aws/iam/virtualmfadevice.pkl"

forma {
    
local myStack = new formae.Stack {
  // Please provide a stack to bring the resources in this Forma under management
label = "test"
  description = "This was generated"
}
myStack

    
local usWest1 = new formae.Target {
  label = "us-west-1"
  namespace = "AWS"
  config {
      Region = "us-west-1"
      Type = "AWS"
    }
}
usWest1

    new virtualmfadevice.VirtualMFADevice {
    label = "arn:aws:iam::123456789012:mfa/example-mfa-device"
    path = "/"
    users = new Listing {  }
    virtualMfaDeviceName = "example-mfa-device"
    target = usWest1.res
    stack = myStack.res
  }
}