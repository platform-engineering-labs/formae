amends "@formae/forma.pkl"
import "@formae/formae.pkl"

// Resource imports
import "@aws/logs/loggroup.pkl"
// Dependency imports
import "@aws/aws.pkl"

forma {
    
local myStack = new formae.Stack {
  // Please provide a stack to bring the resources in this Forma under management
label = "test"
  description = "This was generated"
}
myStack

    
local usWest1 = new formae.Target {
  label = "us-west-1"
  namespace = "AWS"
  config {
      Region = "us-west-1"
      Type = "AWS"
    }
}
usWest1

    new loggroup.LogGroup {
    label = "/aws/eks/example-cluster/cluster"
    logGroupClass = "STANDARD"
    logGroupName = "/aws/eks/example-cluster/cluster"
    retentionInDays = 90
    tags = new Listing<aws.Tag> { new aws.Tag {
      key = "Name"
      value = "/aws/eks/example-cluster/cluster"
    }; new aws.Tag {
      key = "Environment"
      value = "development"
    } }
    target = usWest1.res
    stack = myStack.res
  }

new loggroup.LogGroup {
    label = "/aws/lambda/example-lambda-function"
    logGroupClass = "STANDARD"
    logGroupName = "/aws/lambda/example-lambda-function"
    target = usWest1.res
    stack = myStack.res
  }
}