amends "@formae/forma.pkl"
import "@formae/formae.pkl"

// Resource imports
import "@aws/ec2/routetable.pkl"
// Dependency imports
import "@aws/aws.pkl"

forma {
    
local myStack = new formae.Stack {
  // Please provide a stack to bring the resources in this Forma under management
label = "test"
  description = "This was generated"
}
myStack

    
local usWest2 = new formae.Target {
  label = "us-west-2"
  namespace = "AWS"
  config {
      Region = "us-west-2"
      Type = "AWS"
    }
}
usWest2

    new routetable.RouteTable {
    label = "pel-infra-private"
    tags = new Listing<aws.Tag> { new aws.Tag {
      key = "Name"
      value = "pel-infra-private"
    } }
    vpcId = "vpc-0b0b9599aff98d83d"
    target = usWest2.res
    stack = myStack.res
  }

new routetable.RouteTable {
    label = "pel-infra-public-a-4"
    tags = new Listing<aws.Tag> { new aws.Tag {
      key = "Name"
      value = "pel-infra-public"
    } }
    vpcId = "vpc-0b0b9599aff98d83d"
    target = usWest2.res
    stack = myStack.res
  }

new routetable.RouteTable {
    label = "rtb-0614f11b45a94c35a"
    vpcId = "vpc-0b0b9599aff98d83d"
    target = usWest2.res
    stack = myStack.res
  }

new routetable.RouteTable {
    label = "rtb-06caa1102d61847d9"
    vpcId = "vpc-0a1b225921496c4c4"
    target = usWest2.res
    stack = myStack.res
  }

new routetable.RouteTable {
    label = "rtb-0a412a511795d0ed2"
    vpcId = "vpc-0b8acd158b7d588f2"
    target = usWest2.res
    stack = myStack.res
  }
}