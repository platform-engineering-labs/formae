amends "@formae/forma.pkl"
import "@formae/formae.pkl"

// Resource imports
import "@aws/iam/managedpolicy.pkl"

forma {
    
local myStack = new formae.Stack {
  // Please provide a stack to bring the resources in this Forma under management
label = "test"
  description = "This was generated"
}
myStack

    
local usWest1 = new formae.Target {
  label = "us-west-1"
  namespace = "AWS"
  config {
      Region = "us-west-1"
      Type = "AWS"
    }
}
usWest1

    new managedpolicy.ManagedPolicy {
    label = "arn:aws:iam::aws:policy/AWSSystemsManagerJustInTimeAccessTokenSessionPolicy"
    description = "The managed policy AWSSystemsManagerJustInTimeAccessTokenSessionPolicy allows Systems Manager to apply scoped down permissions to a just-in-time node access session once it is started."
    managedPolicyName = "AWSSystemsManagerJustInTimeAccessTokenSessionPolicy"
    path = "/"
    policyDocument = new Dynamic {
      Statement = new Listing { new Dynamic {
        Action = new Listing { "ssm:StartSession" }
        Effect = "Allow"
        Resource = new Listing { "arn:aws:ssm:*:*:document/SSM-SessionManagerRunShell" }
        Sid = "SsmStartSession"
      }; new Dynamic {
        Action = new Listing { "ssm-guiconnect:CancelConnection"; "ssm-guiconnect:GetConnection"; "ssm-guiconnect:StartConnection" }
        Effect = "Allow"
        Resource = "*"
        Sid = "GuiConnect"
      }; new Dynamic {
        Action = new Listing { "kms:GenerateDataKey" }
        Condition = new Dynamic {
          StringEquals = new Dynamic {
            ["aws:ResourceTag/SystemsManagerJustInTimeNodeAccessManaged"] = "true"
          }
        }
        Effect = "Allow"
        Resource = "arn:aws:kms:*:*:key/*"
        Sid = "SessionManagerKmsPermission"
      }; new Dynamic {
        Action = new Listing { "kms:CreateGrant" }
        Condition = new Dynamic {
          Bool = new Dynamic {
            ["aws:ViaAWSService"] = "true"
          }
          StringEquals = new Dynamic {
            ["aws:ResourceTag/SystemsManagerJustInTimeNodeAccessManaged"] = "true"
          }
          StringLike = new Dynamic {
            ["kms:ViaService"] = "ssm-guiconnect.*.amazonaws.com"
          }
        }
        Effect = "Allow"
        Resource = "arn:aws:kms:*:*:key/*"
        Sid = "RdpKmsPermission"
      }; new Dynamic {
        Action = new Listing { "ssm:StartSession" }
        Condition = new Dynamic {
          StringEquals = new Dynamic {
            ["aws:CalledViaFirst"] = "ssm-guiconnect.amazonaws.com"
          }
        }
        Effect = "Allow"
        Resource = new Listing { "arn:aws:ssm:*:*:document/AWS-StartPortForwardingSession" }
        Sid = "RdpStartSession"
      }; new Dynamic {
        Action = new Listing { "sso:ListDirectoryAssociations*"; "identitystore:DescribeUser"; "ssm:GetCommandInvocation" }
        Condition = new Dynamic {
          StringEquals = new Dynamic {
            ["aws:CalledViaFirst"] = "ssm-guiconnect.amazonaws.com"
          }
        }
        Effect = "Allow"
        Resource = "*"
        Sid = "SsmRdpSsoSetup"
      }; new Dynamic {
        Action = new Listing { "ssm:SendCommand" }
        Condition = new Dynamic {
          StringEquals = new Dynamic {
            ["aws:CalledViaFirst"] = "ssm-guiconnect.amazonaws.com"
          }
        }
        Effect = "Allow"
        Resource = new Listing { "arn:aws:ssm:*:*:document/AWSSSO-CreateSSOUser" }
        Sid = "SsmRdpSsoSetupSendCommand"
      } }
      Version = "2012-10-17"
    }
    target = usWest1.res
    stack = myStack.res
  }

new managedpolicy.ManagedPolicy {
    label = "arn:aws:iam::123456789012:policy/AmazonEKS_EBS_CSI_Policy-example-policy"
    description = "Provides permissions to manage EBS volumes via the container storage interface driver"
    groups = new Listing {  }
    managedPolicyName = "AmazonEKS_EBS_CSI_Policy-example-policy"
    path = "/"
    policyDocument = new Dynamic {
      Statement = new Listing { new Dynamic {
        Action = new Listing { "ec2:ModifyVolume"; "ec2:EnableFastSnapshotRestores"; "ec2:DetachVolume"; "ec2:DescribeVolumesModifications"; "ec2:DescribeVolumes"; "ec2:DescribeTags"; "ec2:DescribeSnapshots"; "ec2:DescribeInstances"; "ec2:DescribeAvailabilityZones"; "ec2:CreateSnapshot"; "ec2:AttachVolume" }
        Effect = "Allow"
        Resource = "*"
      }; new Dynamic {
        Action = "ec2:CreateTags"
        Condition = new Dynamic {
          StringEquals = new Dynamic {
            ["ec2:CreateAction"] = new Listing { "CreateVolume"; "CreateSnapshot" }
          }
        }
        Effect = "Allow"
        Resource = new Listing { "arn:aws:ec2:*:*:volume/*"; "arn:aws:ec2:*:*:snapshot/*" }
      }; new Dynamic {
        Action = "ec2:DeleteTags"
        Effect = "Allow"
        Resource = new Listing { "arn:aws:ec2:*:*:volume/*"; "arn:aws:ec2:*:*:snapshot/*" }
      }; new Dynamic {
        Action = "ec2:CreateVolume"
        Condition = new Dynamic {
          StringLike = new Dynamic {
            ["aws:RequestTag/ebs.csi.aws.com/cluster"] = "true"
          }
        }
        Effect = "Allow"
        Resource = "arn:aws:ec2:*:*:volume/*"
      }; new Dynamic {
        Action = "ec2:CreateVolume"
        Condition = new Dynamic {
          StringLike = new Dynamic {
            ["aws:RequestTag/CSIVolumeName"] = "*"
          }
        }
        Effect = "Allow"
        Resource = "arn:aws:ec2:*:*:volume/*"
      }; new Dynamic {
        Action = "ec2:CreateVolume"
        Condition = new Dynamic {
          StringLike = new Dynamic {
            ["aws:RequestTag/kubernetes.io/cluster/*"] = "owned"
          }
        }
        Effect = "Allow"
        Resource = "*"
      }; new Dynamic {
        Action = "ec2:CreateVolume"
        Effect = "Allow"
        Resource = "arn:aws:ec2:*:*:snapshot/*"
      }; new Dynamic {
        Action = "ec2:DeleteVolume"
        Condition = new Dynamic {
          StringLike = new Dynamic {
            ["ec2:ResourceTag/ebs.csi.aws.com/cluster"] = "true"
          }
        }
        Effect = "Allow"
        Resource = "*"
      }; new Dynamic {
        Action = "ec2:DeleteVolume"
        Condition = new Dynamic {
          StringLike = new Dynamic {
            ["ec2:ResourceTag/CSIVolumeName"] = "*"
          }
        }
        Effect = "Allow"
        Resource = "*"
      }; new Dynamic {
        Action = "ec2:DeleteVolume"
        Condition = new Dynamic {
          StringLike = new Dynamic {
            ["ec2:ResourceTag/kubernetes.io/cluster/*"] = "owned"
          }
        }
        Effect = "Allow"
        Resource = "*"
      }; new Dynamic {
        Action = "ec2:DeleteVolume"
        Condition = new Dynamic {
          StringLike = new Dynamic {
            ["ec2:ResourceTag/kubernetes.io/created-for/pvc/name"] = "*"
          }
        }
        Effect = "Allow"
        Resource = "*"
      }; new Dynamic {
        Action = "ec2:DeleteSnapshot"
        Condition = new Dynamic {
          StringLike = new Dynamic {
            ["ec2:ResourceTag/CSIVolumeSnapshotName"] = "*"
          }
        }
        Effect = "Allow"
        Resource = "*"
      }; new Dynamic {
        Action = "ec2:DeleteSnapshot"
        Condition = new Dynamic {
          StringLike = new Dynamic {
            ["ec2:ResourceTag/ebs.csi.aws.com/cluster"] = "true"
          }
        }
        Effect = "Allow"
        Resource = "*"
      } }
      Version = "2012-10-17"
    }
    roles = new Listing {  }
    users = new Listing {  }
    target = usWest1.res
    stack = myStack.res
  }

new managedpolicy.ManagedPolicy {
    label = "arn:aws:iam::123456789012:policy/service-role/AWSLambdaBasicExecutionRole-example-lambda-role"
    description = ""
    managedPolicyName = "AWSLambdaBasicExecutionRole-example-lambda-role"
    path = "/service-role/"
    policyDocument = new Dynamic {
      Statement = new Listing { new Dynamic {
        Action = "logs:CreateLogGroup"
        Effect = "Allow"
        Resource = "arn:aws:logs:us-east-1:123456789012:*"
      }; new Dynamic {
        Action = new Listing { "logs:CreateLogStream"; "logs:PutLogEvents" }
        Effect = "Allow"
        Resource = new Listing { "arn:aws:logs:us-east-1:123456789012:log-group:/aws/lambda/example-skill:*" }
      } }
      Version = "2012-10-17"
    }
    roles = new Listing { "example-skill-role" }
    target = usWest1.res
    stack = myStack.res
  }

new managedpolicy.ManagedPolicy {
    label = "arn:aws:iam::123456789012:policy/example-modules.example-ecr-create-repository"
    description = "Create ECR repository"
    groups = new Listing {  }
    managedPolicyName = "example-modules.example-ecr-create-repository"
    path = "/"
    policyDocument = new Dynamic {
      Statement = new Listing { new Dynamic {
        Action = "ecr:CreateRepository"
        Effect = "Allow"
        Resource = "*"
      } }
      Version = "2012-10-17"
    }
    roles = new Listing { "example-development-modules-role" }
    users = new Listing {  }
    target = usWest1.res
    stack = myStack.res
  }

new managedpolicy.ManagedPolicy {
    label = "arn:aws:iam::123456789012:policy/example_admin_policy"
    description = "Example admin access policy"
    groups = new Listing {  }
    managedPolicyName = "example_admin_policy"
    path = "/"
    policyDocument = new Dynamic {
      Statement = new Listing { new Dynamic {
        Action = new Listing { "eks:Describe*"; "eks:List*"; "eks:Create*"; "eks:Delete*"; "eks:Modify*" }
        Effect = "Allow"
        Resource = "*"
      } }
      Version = "2012-10-17"
    }
    roles = new Listing {  }
    users = new Listing {  }
    target = usWest1.res
    stack = myStack.res
  }

new managedpolicy.ManagedPolicy {
    label = "arn:aws:iam::123456789012:policy/example_access_key_policy"
    description = "Policy to allow access key creation for a specific user"
    groups = new Listing {  }
    managedPolicyName = "example_access_key_policy"
    path = "/"
    policyDocument = new Dynamic {
      Statement = new Listing { new Dynamic {
        Action = new Listing { "iam:CreateAccessKey"; "iam:ListUsers" }
        Effect = "Allow"
        Resource = "arn:aws:iam::123456789012:user/example.user"
      } }
      Version = "2012-10-17"
    }
    roles = new Listing {  }
    users = new Listing {  }
    target = usWest1.res
    stack = myStack.res
  }

new managedpolicy.ManagedPolicy {
    label = "arn:aws:iam::123456789012:policy/example_lambda_ses_forwarder"
    description = ""
    groups = new Listing {  }
    managedPolicyName = "example_lambda_ses_forwarder"
    path = "/"
    policyDocument = new Dynamic {
      Statement = new Listing { new Dynamic {
        Action = new Listing { "logs:CreateLogGroup"; "logs:CreateLogStream"; "logs:PutLogEvents" }
        Effect = "Allow"
        Resource = "arn:aws:logs:*:*:*"
      }; new Dynamic {
        Action = "ses:SendEmail"
        Effect = "Allow"
        Resource = "*"
      }; new Dynamic {
        Action = new Listing { "s3:GetObject"; "s3:PutObject" }
        Effect = "Allow"
        Resource = "arn:aws:s3:::example-ses-forwarder/*"
      } }
      Version = "2012-10-17"
    }
    roles = new Listing {  }
    users = new Listing {  }
    target = usWest1.res
    stack = myStack.res
  }

new managedpolicy.ManagedPolicy {
    label = "arn:aws:iam::123456789012:policy/service-role/ExampleRolePolicy-example-cicd-role"
    description = "Example service role policy"
    managedPolicyName = "ExampleRolePolicy-example-cicd-role"
    path = "/service-role/"
    policyDocument = new Dynamic {
      Statement = new Listing { new Dynamic {
        Action = new Listing { "cloudformation:CancelUpdateStack"; "cloudformation:ContinueUpdateRollback"; "cloudformation:CreateChangeSet"; "cloudformation:CreateStack"; "cloudformation:DeleteChangeSet"; "cloudformation:DeleteStack"; "cloudformation:DescribeChangeSet"; "cloudformation:DescribeStackDriftDetectionStatus"; "cloudformation:DescribeStackEvents"; "cloudformation:DescribeStackResourceDrifts"; "cloudformation:DescribeStacks"; "cloudformation:DetectStackResourceDrift"; "cloudformation:ExecuteChangeSet"; "cloudformation:ListChangeSets"; "cloudformation:ListStackResources"; "cloudformation:UpdateStack" }
        Effect = "Allow"
        Resource = "arn:aws:cloudformation:*:123456789012:stack/ExampleStack-*"
      }; new Dynamic {
        Condition = new Dynamic {
          ["ForAnyValue:StringEquals"] = new Dynamic {
            ["aws:CalledVia"] = new Listing { "cloudformation.amazonaws.com" }
          }
        }
        Effect = "Allow"
        NotAction = new Listing { "organizations:*"; "account:*" }
        Resource = "*"
      }; new Dynamic {
        Action = new Listing { "organizations:DescribeOrganization"; "account:ListRegions" }
        Condition = new Dynamic {
          ["ForAnyValue:StringEquals"] = new Dynamic {
            ["aws:CalledVia"] = new Listing { "cloudformation.amazonaws.com" }
          }
        }
        Effect = "Allow"
        Resource = "*"
      } }
      Version = "2012-10-17"
    }
    roles = new Listing { "example-cicd-role" }
    target = usWest1.res
    stack = myStack.res
  }

new managedpolicy.ManagedPolicy {
    label = "arn:aws:iam::123456789012:policy/example-cluster-policy"
    description = ""
    managedPolicyName = "example-cluster-policy"
    path = "/"
    policyDocument = new Dynamic {
      Statement = new Listing { new Dynamic {
        Action = new Listing { "ec2:RunInstances"; "ec2:CreateLaunchTemplate"; "ec2:CreateFleet" }
        Condition = new Dynamic {
          StringEquals = new Dynamic {
            ["aws:RequestTag/eks:eks-cluster-name"] = "${aws:PrincipalTag/eks:eks-cluster-name}"
          }
          StringLike = new Dynamic {
            ["aws:RequestTag/eks:kubernetes-node-class-name"] = "*"
            ["aws:RequestTag/eks:kubernetes-node-pool-name"] = "*"
          }
        }
        Effect = "Allow"
        Resource = "*"
        Sid = "Compute"
      }; new Dynamic {
        Action = new Listing { "ec2:CreateVolume"; "ec2:CreateSnapshot" }
        Condition = new Dynamic {
          StringEquals = new Dynamic {
            ["aws:RequestTag/eks:eks-cluster-name"] = "${aws:PrincipalTag/eks:eks-cluster-name}"
          }
        }
        Effect = "Allow"
        Resource = new Listing { "arn:aws:ec2:*:*:volume/*"; "arn:aws:ec2:*:*:snapshot/*" }
        Sid = "Storage"
      }; new Dynamic {
        Action = "ec2:CreateNetworkInterface"
        Condition = new Dynamic {
          StringEquals = new Dynamic {
            ["aws:RequestTag/eks:eks-cluster-name"] = "${aws:PrincipalTag/eks:eks-cluster-name}"
            ["aws:RequestTag/eks:kubernetes-cni-node-name"] = "*"
          }
        }
        Effect = "Allow"
        Resource = "*"
        Sid = "Networking"
      }; new Dynamic {
        Action = new Listing { "elasticloadbalancing:CreateTargetGroup"; "elasticloadbalancing:CreateRule"; "elasticloadbalancing:CreateLoadBalancer"; "elasticloadbalancing:CreateListener"; "ec2:CreateSecurityGroup" }
        Condition = new Dynamic {
          StringEquals = new Dynamic {
            ["aws:RequestTag/eks:eks-cluster-name"] = "${aws:PrincipalTag/eks:eks-cluster-name}"
          }
        }
        Effect = "Allow"
        Resource = "*"
        Sid = "LoadBalancer"
      }; new Dynamic {
        Action = "shield:CreateProtection"
        Condition = new Dynamic {
          StringEquals = new Dynamic {
            ["aws:RequestTag/eks:eks-cluster-name"] = "${aws:PrincipalTag/eks:eks-cluster-name}"
          }
        }
        Effect = "Allow"
        Resource = "*"
        Sid = "ShieldProtection"
      }; new Dynamic {
        Action = "shield:TagResource"
        Condition = new Dynamic {
          StringEquals = new Dynamic {
            ["aws:ResourceTag/eks:eks-cluster-name"] = "${aws:PrincipalTag/eks:eks-cluster-name}"
          }
        }
        Effect = "Allow"
        Resource = "arn:aws:shield::*:protection/*"
        Sid = "ShieldTagResource"
      } }
      Version = "2012-10-17"
    }
    roles = new Listing { "example-cluster-role" }
    target = usWest1.res
    stack = myStack.res
  }

new managedpolicy.ManagedPolicy {
    label = "arn:aws:iam::123456789012:policy/example-cluster-encryption-policy"
