      } }
      Version = "2012-10-17"
    }
    roles = new Listing { "example-cluster-role" }
    users = new Listing {  }
    target = usWest1.res
    stack = myStack.res
  }

new managedpolicy.ManagedPolicy {
    label = "arn:aws:iam::123456789012:policy/example_ses_sender"
    description = "Allows sending of e-mails via Simple Email Service"
    managedPolicyName = "example_ses_sender"
    path = "/"
    policyDocument = new Dynamic {
      Statement = new Listing { new Dynamic {
        Action = "ses:SendRawEmail"
        Effect = "Allow"
        Resource = "*"
        Sid = ""
      } }
      Version = "2012-10-17"
    }
    target = usWest1.res
    stack = myStack.res
  }
}