amends "@formae/forma.pkl"
import "@formae/formae.pkl"

// Resource imports
import "@aws/sqs/queue.pkl"
// Dependency imports
import "@aws/aws.pkl"

forma {
    
local pelQueue = new formae.Stack {
          label = "pel-queue"
  description = "This was generated"
}
pelQueue

    
local defaultAwsTargett = new formae.Target {
  label = "default-aws-targett"
  namespace = "AWS"
  config {
      Type = "AWS"
      Region = "us-west-2"
    }
}
defaultAwsTargett

    new queue.Queue {
    label = "dead-letter-queue"
    delaySeconds = 0.s
    maximumMessageSize = 262144.b
    messageRetentionPeriod = 345600.s
    queueName = "pel-sqs-queue-dlq"
    receiveMessageWaitTimeSeconds = 0.s
    sqsManagedSseEnabled = true
    tags = new Listing<aws.Tag> { new aws.Tag {
      key = "Purpose"
      value = "DeadLetter"
    } }
    visibilityTimeout = 300.s
    target = defaultAwsTargett.res
    stack = pelQueue.res
  }

new queue.Queue {
    label = "fifo-queue"
    contentBasedDeduplication = true
    deduplicationScope = "messageGroup"
    delaySeconds = 0.s
    fifoQueue = true
    fifoThroughputLimit = "perQueue"
    maximumMessageSize = 262144.b
    messageRetentionPeriod = 345600.s
    queueName = "pel-sqs-queue.fifo"
    receiveMessageWaitTimeSeconds = 0.s
    sqsManagedSseEnabled = true
    tags = new Listing<aws.Tag> { new aws.Tag {
      key = "Type"
      value = "FIFO"
    } }
    visibilityTimeout = 3.s
    target = defaultAwsTargett.res
    stack = pelQueue.res
  }

new queue.Queue {
    label = "queue-with-dlq"
    delaySeconds = 0.s
    maximumMessageSize = 262144.b
    messageRetentionPeriod = 345600.s
    queueName = "pel-sqs-queue-with-dlq"
    receiveMessageWaitTimeSeconds = 0.s
    redrivePolicy = new Dynamic {
      deadLetterTargetArn = new Dynamic {
        $label = "dead-letter-queue"
        $property = "Arn"
        $res = true
        $stack = pelQueue.res
        $type = "AWS::SQS::Queue"
        $value = "arn:aws:sqs:us-west-2:021891619792:pel-sqs-queue-dlq"
      }
      maxReceiveCount = 3
    }
    sqsManagedSseEnabled = true
    visibilityTimeout = 300.s
    target = defaultAwsTargett.res
    stack = pelQueue.res
  }

new queue.Queue {
    label = "queue-with-inline-policy"
    delaySeconds = 0.s
    maximumMessageSize = 262144.b
    messageRetentionPeriod = 345600.s
    queueName = "pel-sqs-queue-inline"
    receiveMessageWaitTimeSeconds = 0.s
    sqsManagedSseEnabled = true
    visibilityTimeout = 300.s
    target = defaultAwsTargett.res
    stack = pelQueue.res
  }

new queue.Queue {
    label = "standard-queue"
    delaySeconds = 0.s
    maximumMessageSize = 262144.b
    messageRetentionPeriod = 345600.s
    queueName = "pel-sqs-queue"
    receiveMessageWaitTimeSeconds = 0.s
    sqsManagedSseEnabled = true
    tags = new Listing<aws.Tag> { new aws.Tag {
      key = "Environment"
      value = "Production"
    } }
    visibilityTimeout = 300.s
    target = defaultAwsTargett.res
    stack = pelQueue.res
  }
}