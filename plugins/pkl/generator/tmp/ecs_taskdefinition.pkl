amends "@formae/forma.pkl"
import "@formae/formae.pkl"

// Resource imports
import "@aws/ecs/taskdefinition.pkl"
// Dependency imports
import "@aws/aws.pkl"

forma {
    
local myStack = new formae.Stack {
  // Please provide a stack to bring the resources in this Forma under management
label = "test"
  description = "This was generated"
}
myStack

    
local usWest1 = new formae.Target {
  label = "us-west-1"
  namespace = "AWS"
  config {
      Region = "us-west-1"
      Type = "AWS"
    }
}
usWest1

    new taskdefinition.TaskDefinition {
    label = "example-app-task-def"
    containerDefinitions = new Listing { new taskdefinition.ContainerDefinition {
      cpu = 0
      essential = true
      image = "nginx:latest"
      logConfiguration = new taskdefinition.LogConfiguration {
        logDriver = "awslogs"
        options = new Mapping {
          ["awslogs-group"] = "/ecs/example-app"
          ["awslogs-region"] = "us-west-1"
          ["awslogs-stream-prefix"] = "ecs"
        }
      }
      name = "example-app-container"
      portMappings = new Listing { new taskdefinition.PortMapping {
        containerPort = 80
        hostPort = 80
        protocol = "tcp"
      } }
    } }
    cpu = "256"
    executionRoleArn = "arn:aws:iam::123456789012:role/ecsTaskExecutionRole"
    family = "example-app-task"
    memory = "512"
    networkMode = "awsvpc"
    requiresCompatibilities = new Listing { "FARGATE" }
    tags = new Listing<aws.Tag> { new aws.Tag {
      key = "Name"
      value = "example-app-task-def"
    } }
    target = usWest1.res
    stack = myStack.res
  }

new taskdefinition.TaskDefinition {
    label = "backend-service-task-def"
    containerDefinitions = new Listing { new taskdefinition.ContainerDefinition {
      cpu = 0
      environment = new Listing { new taskdefinition.KeyValuePair {
        name = "NODE_ENV"
        value = "production"
      }; new taskdefinition.KeyValuePair {
        name = "PORT"
        value = "8080"
      } }
      essential = true
      image = "123456789012.dkr.ecr.us-west-1.amazonaws.com/backend-service:latest"
      logConfiguration = new taskdefinition.LogConfiguration {
        logDriver = "awslogs"
        options = new Mapping {
          ["awslogs-group"] = "/ecs/backend-service"
          ["awslogs-region"] = "us-west-1"
          ["awslogs-stream-prefix"] = "ecs"
        }
      }
      name = "backend-service-container"
      portMappings = new Listing { new taskdefinition.PortMapping {
        containerPort = 8080
        protocol = "tcp"
      } }
    } }
    cpu = "512"
    executionRoleArn = "arn:aws:iam::123456789012:role/ecsTaskExecutionRole"
    family = "backend-service-task"
    memory = "1024"
    networkMode = "awsvpc"
    requiresCompatibilities = new Listing { "FARGATE" }
    taskRoleArn = "arn:aws:iam::123456789012:role/ecsTaskRole"
    target = usWest1.res
    stack = myStack.res
  }

new taskdefinition.TaskDefinition {
    label = "worker-task-def"
    containerDefinitions = new Listing { new taskdefinition.ContainerDefinition {
      cpu = 0
      environment = new Listing { new taskdefinition.KeyValuePair {
        name = "QUEUE_URL"
        value = "https://sqs.us-west-1.amazonaws.com/123456789012/example-queue"
      }; new taskdefinition.KeyValuePair {
        name = "BATCH_SIZE"
        value = "10"
      } }
      essential = true
      image = "123456789012.dkr.ecr.us-west-1.amazonaws.com/data-processor:latest"
      logConfiguration = new taskdefinition.LogConfiguration {
        logDriver = "awslogs"
        options = new Mapping {
          ["awslogs-group"] = "/ecs/worker-service"
          ["awslogs-region"] = "us-west-1"
          ["awslogs-stream-prefix"] = "ecs"
        }
      }
      name = "worker-container"
    } }
    cpu = "1024"
    executionRoleArn = "arn:aws:iam::123456789012:role/ecsTaskExecutionRole"
    family = "worker-task"
    memory = "2048"
    networkMode = "awsvpc"
    requiresCompatibilities = new Listing { "FARGATE" }
    taskRoleArn = "arn:aws:iam::123456789012:role/workerTaskRole"
    target = usWest1.res
    stack = myStack.res
  }
}