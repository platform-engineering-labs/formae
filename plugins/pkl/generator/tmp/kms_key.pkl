        Effect = "Allow"
        Principal = new Dynamic {
          AWS = "arn:aws:iam::123456789012:root"
        }
        Resource = "*"
        Sid = "Allow direct access to key metadata to the account"
      } }
      Version = "2012-10-17"
    }
    keySpec = "SYMMETRIC_DEFAULT"
    keyUsage = "ENCRYPT_DECRYPT"
    multiRegion = false
    origin = "AWS_KMS"
    tags = new Listing {}
    target = usWest1.res
    stack = myStack.res
  }

new key.Key {
    label = "56789012-5678-5678-5678-567890123456"
    description = "Default key that protects my SNS data when no other key is defined"
    enableKeyRotation = true
    enabled = true
    keyPolicy = new Dynamic {
      Id = "auto-sns-2"
      Statement = new Listing { new Dynamic {
        Action = new Listing { "kms:Decrypt"; "kms:GenerateDataKey*"; "kms:CreateGrant"; "kms:ListGrants"; "kms:DescribeKey" }
        Condition = new Dynamic {
          StringEquals = new Dynamic {
            ["kms:CallerAccount"] = "123456789012"
            ["kms:ViaService"] = "sns.us-west-1.amazonaws.com"
          }
        }
        Effect = "Allow"
        Principal = new Dynamic {
          AWS = "*"
        }
        Resource = "*"
        Sid = "Allow access through SNS for all principals in the account that are authorized to use SNS"
      }; new Dynamic {
        Action = new Listing { "kms:Describe*"; "kms:Get*"; "kms:List*"; "kms:RevokeGrant" }
        Effect = "Allow"
        Principal = new Dynamic {
          AWS = "arn:aws:iam::123456789012:root"
        }
        Resource = "*"
        Sid = "Allow direct access to key metadata to the account"
      }; new Dynamic {
        Action = "kms:Decrypt"
        Condition = new Dynamic {
          ArnLike = new Dynamic {
            ["aws:SourceArn"] = "arn:*:sns:us-west-1:123456789012:*"
          }
          StringEquals = new Dynamic {
            ["aws:SourceAccount"] = "123456789012"
          }
        }
        Effect = "Allow"
        Principal = new Dynamic {
          Service = "sns.amazonaws.com"
        }
        Resource = "*"
        Sid = "Allow SNS to decrypt archived messages"
      } }
      Version = "2012-10-17"
    }
    keySpec = "SYMMETRIC_DEFAULT"
    keyUsage = "ENCRYPT_DECRYPT"
    multiRegion = false
    origin = "AWS_KMS"
    target = usWest1.res
    stack = myStack.res
  }

new key.Key {
    label = "67890123-6789-6789-6789-678901234567"
