amends "@formae/forma.pkl"
import "@formae/formae.pkl"

// Resource imports
import "@aws/kms/key.pkl"

forma {
    
local myStack = new formae.Stack {
  // Please provide a stack to bring the resources in this Forma under management
label = "test"
  description = "This was generated"
}
myStack

    
local usWest1 = new formae.Target {
  label = "us-west-1"
  namespace = "AWS"
  config {
      Region = "us-west-1"
      Type = "AWS"
    }
}
usWest1

    new key.Key {
    label = "12345678-1234-1234-1234-123456789012"
    description = "Default master key that protects my ACM private keys when no other key is defined"
    enabled = true
    keyPolicy = new Dynamic {
      Id = "auto-acm-4"
      Statement = new Listing { new Dynamic {
        Action = "kms:CreateGrant"
        Condition = new Dynamic {
          Bool = new Dynamic {
            ["kms:GrantIsForAWSResource"] = "true"
          }
          ["ForAllValues:StringEquals"] = new Dynamic {
            ["kms:GrantOperations"] = "Decrypt"
          }
          StringEquals = new Dynamic {
            ["kms:CallerAccount"] = "123456789012"
            ["kms:ViaService"] = "acm.us-west-1.amazonaws.com"
          }
        }
        Effect = "Allow"
        Principal = new Dynamic {
          AWS = "*"
        }
        Resource = "*"
        Sid = "Allow creation of decryption grants"
      }; new Dynamic {
        Action = "kms:CreateGrant"
        Condition = new Dynamic {
          Bool = new Dynamic {
            ["kms:GrantIsForAWSResource"] = "true"
          }
          ["ForAllValues:StringEquals"] = new Dynamic {
            ["kms:GrantOperations"] = new Listing { "Encrypt"; "ReEncryptFrom"; "ReEncryptTo" }
          }
          StringEquals = new Dynamic {
            ["kms:CallerAccount"] = "123456789012"
            ["kms:ViaService"] = "acm.us-west-1.amazonaws.com"
          }
        }
        Effect = "Allow"
        Principal = new Dynamic {
          AWS = "*"
        }
        Resource = "*"
        Sid = "Allow creation of encryption grant"
      }; new Dynamic {
        Action = new Listing { "kms:DescribeKey"; "kms:ListGrants"; "kms:RevokeGrant"; "kms:GetKeyPolicy" }
        Condition = new Dynamic {
          StringEquals = new Dynamic {
            ["kms:CallerAccount"] = "123456789012"
          }
        }
        Effect = "Allow"
        Principal = new Dynamic {
          AWS = "*"
        }
        Resource = "*"
        Sid = "Allowed operations for the key owner"
      }; new Dynamic {
        Action = "kms:ReEncrypt*"
        Condition = new Dynamic {
          Bool = new Dynamic {
            ["kms:ReEncryptOnSameKey"] = "false"
          }
        }
        Effect = "Deny"
        Principal = new Dynamic {
          AWS = "*"
        }
        Resource = "*"
        Sid = "Deny re-encryption to any other key"
      }; new Dynamic {
        Action = "kms:Decrypt"
        Condition = new Dynamic {
          StringEquals = new Dynamic {
            ["kms:CallerAccount"] = "123456789012"
            ["kms:ViaService"] = "acm.us-west-1.amazonaws.com"
          }
        }
        Effect = "Allow"
        Principal = new Dynamic {
          AWS = "*"
        }
        Resource = "*"
        Sid = "Allow decrypt"
      } }
      Version = "2012-10-17"
    }
    keySpec = "SYMMETRIC_DEFAULT"
    keyUsage = "ENCRYPT_DECRYPT"
    multiRegion = false
    origin = "AWS_KMS"
    target = usWest1.res
    stack = myStack.res
  }

new key.Key {
    label = "23456789-2345-2345-2345-234567890123"
    description = "Default key that protects my S3 objects when no other key is defined"
    enableKeyRotation = true
    enabled = true
    keyPolicy = new Dynamic {
      Id = "auto-s3-2"
      Statement = new Listing { new Dynamic {
        Action = new Listing { "kms:Encrypt"; "kms:Decrypt"; "kms:ReEncrypt*"; "kms:GenerateDataKey*"; "kms:DescribeKey" }
        Condition = new Dynamic {
          StringEquals = new Dynamic {
            ["kms:CallerAccount"] = "123456789012"
            ["kms:ViaService"] = "s3.us-west-1.amazonaws.com"
          }
        }
        Effect = "Allow"
        Principal = new Dynamic {
          AWS = "*"
        }
        Resource = "*"
        Sid = "Allow access through S3 for all principals in the account that are authorized to use S3"
      }; new Dynamic {
        Action = new Listing { "kms:Describe*"; "kms:Get*"; "kms:List*" }
        Effect = "Allow"
        Principal = new Dynamic {
          AWS = "arn:aws:iam::123456789012:root"
        }
        Resource = "*"
        Sid = "Allow direct access to key metadata to the account"
      } }
      Version = "2012-10-17"
    }
    keySpec = "SYMMETRIC_DEFAULT"
    keyUsage = "ENCRYPT_DECRYPT"
    multiRegion = false
    origin = "AWS_KMS"
    target = usWest1.res
    stack = myStack.res
  }

new key.Key {
    label = "34567890-3456-3456-3456-345678901234"
    description = "Default key that protects my Secrets Manager data when no other key is defined"
    enableKeyRotation = true
    enabled = true
    keyPolicy = new Dynamic {
      Id = "auto-secretsmanager-2"
      Statement = new Listing { new Dynamic {
        Action = new Listing { "kms:Encrypt"; "kms:Decrypt"; "kms:ReEncrypt*"; "kms:CreateGrant"; "kms:DescribeKey" }
        Condition = new Dynamic {
          StringEquals = new Dynamic {
            ["kms:CallerAccount"] = "123456789012"
            ["kms:ViaService"] = "secretsmanager.us-west-1.amazonaws.com"
          }
        }
        Effect = "Allow"
        Principal = new Dynamic {
          AWS = "*"
        }
        Resource = "*"
        Sid = "Allow access through AWS Secrets Manager for all principals in the account that are authorized to use AWS Secrets Manager"
      }; new Dynamic {
        Action = "kms:GenerateDataKey*"
        Condition = new Dynamic {
          StringEquals = new Dynamic {
            ["kms:CallerAccount"] = "123456789012"
          }
          StringLike = new Dynamic {
            ["kms:ViaService"] = "secretsmanager.*.amazonaws.com"
          }
        }
        Effect = "Allow"
        Principal = new Dynamic {
          AWS = "*"
        }
        Resource = "*"
        Sid = "Allow access through AWS Secrets Manager for all principals in the account that are authorized to use AWS Secrets Manager"
      }; new Dynamic {
        Action = new Listing { "kms:Describe*"; "kms:Get*"; "kms:List*"; "kms:RevokeGrant" }
        Effect = "Allow"
        Principal = new Dynamic {
          AWS = "arn:aws:iam::123456789012:root"
        }
        Resource = "*"
        Sid = "Allow direct access to key metadata to the account"
      } }
      Version = "2012-10-17"
    }
    keySpec = "SYMMETRIC_DEFAULT"
    keyUsage = "ENCRYPT_DECRYPT"
    multiRegion = false
    origin = "AWS_KMS"
    tags = new Listing {}
    target = usWest1.res
    stack = myStack.res
  }

new key.Key {
    label = "45678901-4567-4567-4567-456789012345"
    description = "Default key that protects my Backup data when no other key is defined"
    enableKeyRotation = true
    enabled = true
    keyPolicy = new Dynamic {
      Id = "auto-backup-1"
      Statement = new Listing { new Dynamic {
        Action = new Listing { "kms:CreateGrant"; "kms:Decrypt"; "kms:GenerateDataKey*" }
        Condition = new Dynamic {
          StringEquals = new Dynamic {
            ["kms:CallerAccount"] = "123456789012"
            ["kms:ViaService"] = "backup.us-west-1.amazonaws.com"
          }
