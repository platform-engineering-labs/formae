amends "@formae/forma.pkl"
import "@formae/formae.pkl"

// Resource imports
import "@aws/ec2/vpcdhcpoptionsassociation.pkl"

forma {
    
local myStack = new formae.Stack {
  // Please provide a stack to bring the resources in this Forma under management
label = "test"
  description = "This was generated"
}
myStack

    
local usWest1 = new formae.Target {
  label = "us-west-1"
  namespace = "AWS"
  config {
      Region = "us-west-1"
      Type = "AWS"
    }
}
usWest1

    new vpcdhcpoptionsassociation.VPCDHCPOptionsAssociation {
    label = "dopt-01234567|vpc-01234567"
    dhcpOptionsId = "dopt-01234567"
    vpcId = "vpc-01234567"
    target = usWest1.res
    stack = myStack.res
  }
}