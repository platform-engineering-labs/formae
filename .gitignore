# If you prefer the allow list template instead of the deny list, see community template:
# https://github.com/github/gitignore/blob/main/community/Golang/Go.AllowList.gitignore
#
# Binaries for programs and plugins
*.exe
*.exe~
*.dll
*.so
*.dylib

# AWS plugin binaries (not built as .so)
plugins/aws/aws
plugins/aws/aws-debug

# Test binary, built with `go test -c`
*.test

# Output of the go coverage tool, specifically when used with LiteIDE
*.out

# Dependency directories (remove the comment below to include it)
# vendor/

# Go workspace file
go.work
go.work.sum

# env file
.env

__debug*

.vscode/
.DS_Store
.idea/

# bin
/formae
!*/formae

# tools
/ppm
!*/ppm
dist/

# goflow ui. Get it locally from https://github.com/fieldryand/goflow/releases/latest/download/goflow-ui.tar.gz
# and extract it into ui/
ui

# Ignore everything in the data folder...
data/*

# Ignore local logs
log/*

# No packages
*.tgz
*.opkg

# PKL ignores
PklProject.deps.json
.out/
.pkl-lsp

# Generated PKL files for local development (regenerated by make test-generator-pkl)
internal/schema/pkl/generator/imports.pkl
internal/schema/pkl/generator/resources.pkl
internal/schema/pkl/generator/resolvables.pkl

# semver files generated during build
version.semver

# e2e test node logs
tests/e2e/formae-server.log
tests/e2e/test-logs

# Generated e2e test PklProject (contains absolute paths, regenerated by setup_pkl.sh)
tests/e2e/pkl/PklProject
tests/e2e/go/fixtures/PklProject

# Claude Code and MCP tooling
.claude/
CLAUDE.md
.serena/

# Local notes, investigation docs, and handoffs (live in engineering-notes)
.plans/
.handoffs/
.research/
docs/design/

# Generated mutation testing report
.mutation-report/

# Git worktrees
.worktrees/

# External plugin cache (cloned plugin repos during build)
.plugins/
channel
