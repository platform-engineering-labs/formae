amends "@formae/forma.pkl"
import "@formae/formae.pkl"

import "@aws/aws.pkl"

import "@aws/iam/role.pkl"
import "@aws/iam/rolepolicy.pkl"

local parentRole = new role.Role {
  label = "e2e-extract-reapply-role"
  roleName = "formae-e2e-extract-reapply-role"
  description = "e2e extract reapply test role"
  assumeRolePolicyDocument = new Dynamic {
    ["Version"] = "2012-10-17"
    ["Statement"] = new Listing {
      new Dynamic {
        ["Effect"] = "Allow"
        ["Principal"] = new Dynamic {
          ["Service"] = "lambda.amazonaws.com"
        }
        ["Action"] = "sts:AssumeRole"
      }
    }
  }
}

local testPolicy = new rolepolicy.RolePolicy {
  label = "e2e-extract-reapply-policy"
  roleName = parentRole.res.roleName
  policyName = "formae-e2e-extract-reapply-policy"
  policyDocument = new Dynamic {
    ["Version"] = "2012-10-17"
    ["Statement"] = new Listing {
      new Dynamic {
        ["Effect"] = "Allow"
        ["Action"] = "logs:DescribeLogGroups"
        ["Resource"] = "*"
      }
    }
  }
}

local stackName = "e2e-extract-reapply-aws"

forma {
  new formae.Stack {
    label = stackName
    description = "E2E extract and reapply test for AWS IAM"
  }

  new formae.Target {
    label = "e2e-aws-target"
    config = new aws.Config {
      region = "us-west-2"
    }
  }

  parentRole

  testPolicy
}
