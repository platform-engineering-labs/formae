amends "@formae/forma.pkl"
import "@formae/formae.pkl"

import "@aws/aws.pkl"

import "@aws/iam/role.pkl"

local parentRole = new role.Role {
  label = "e2e-extract-schema-local-role"
  roleName = "formae-e2e-extract-schema-local-role"
  description = "e2e extract --schema-location local test role"
  assumeRolePolicyDocument = new Dynamic {
    ["Version"] = "2012-10-17"
    ["Statement"] = new Listing {
      new Dynamic {
        ["Effect"] = "Allow"
        ["Principal"] = new Dynamic {
          ["Service"] = "lambda.amazonaws.com"
        }
        ["Action"] = "sts:AssumeRole"
      }
    }
  }
}

local stackName = "e2e-extract-schema-local-aws"

forma {
  new formae.Stack {
    label = stackName
    description = "E2E extract --schema-location local test fixture"
  }

  new formae.Target {
    label = "e2e-aws-target"
    config = new aws.Config {
      region = "us-west-2"
    }
  }

  parentRole
}
