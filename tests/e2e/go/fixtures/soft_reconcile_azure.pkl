amends "@formae/forma.pkl"
import "@formae/formae.pkl"

import "@azure/azure.pkl"

import "@azure/resources/resourcegroup.pkl"

local testRg = new resourcegroup.ResourceGroup {
  label = "e2e-soft-reconcile-rg"
  name = "formae-e2e-soft-reconcile-rg"
  location = "westeurope"
}

local stackName = "e2e-soft-reconcile-azure"

forma {
  new formae.Stack {
    label = stackName
    description = "E2E soft reconcile test for Azure"
  }

  new formae.Target {
    label = "e2e-azure-target"
    config = new azure.Config {
      subscriptionId = read("env:AZURE_SUBSCRIPTION_ID")
    }
  }

  testRg
}
