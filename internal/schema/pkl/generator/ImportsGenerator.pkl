/// Generates imports.pkl with wildcard imports for schema packages.
///
/// This module reads dependencies from PklProject and generates import*() calls
/// for each schema package dependency (excludes the "formae" core library).
///
/// External property `schemaVersions` (optional, format
/// "pkg=ver,pkg=ver") narrows the import glob for matching packages from
/// "@<pkg>/**/*.pkl" to "@<pkg>/*.pkl" + "@<pkg>/<ver>/**/*.pkl". This lets
/// versioned plugins (e.g. k8s) ship a multi-version schema tree under a
/// single PklProject and have callers select one subtree at evaluation time.
///
/// Usage:
///   pkl eval ImportsGenerator.pkl
///
/// Output:
///   packages: Mapping<String, Mapping<String, Module>> = new Mapping {
///     ["@aws"] = import*("@aws/**/*.pkl")
///     ["@k8s"] = import*("@k8s/*.pkl") + import*("@k8s/v1.30/**/*.pkl")
///   }
module formae.generator.ImportsGenerator

import "PklProject"

/// Dependencies to exclude from schema imports (core libraries, not resource providers)
local excludedDependencies: List<String> = List("formae")

/// Get dependency names from PklProject, excluding core libraries
local schemaPackageNames: List<String> =
    PklProject.dependencies.keys.toList().filter((name) -> !excludedDependencies.contains(name))

/// External "pkg=ver,pkg=ver" mapping. Empty string when no versions selected.
local schemaVersionsRaw: String = read?("prop:schemaVersions") ?? ""

/// Parsed: lowercase pkg name -> version string (e.g. "v1.30").
local schemaVersions: Mapping<String, String> = new Mapping {
    for (entry in schemaVersionsRaw.split(",")) {
        when (entry.contains("=")) {
            [entry.split("=")[0].trim().toLowerCase()] = entry.split("=")[1].trim()
        }
    }
}

local function versionFor(name: String): String =
    schemaVersions.getOrNull(name.toLowerCase()) ?? ""

output {
    text = new Listing {
        "// Generated by ImportsGenerator.pkl"
        "// Do not edit manually"
        ""
        "packages: Mapping<String, Mapping<String, Module>> = new Mapping {"
        for (name in schemaPackageNames) {
            let (ver = versionFor(name))
                if (ver == "")
                    "    [\"@\(name)\"] = new Mapping { ...import*(\"@\(name)/*.pkl\"); ...import*(\"@\(name)/**/*.pkl\") }"
                else
                    "    [\"@\(name)\"] = new Mapping { ...import*(\"@\(name)/*.pkl\"); ...import*(\"@\(name)/\(ver)/**/*.pkl\") }"
        }
        "}"
    }.join("\n")
}
