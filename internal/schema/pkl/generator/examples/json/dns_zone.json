{
  "Targets": [
    {
      "Label": "testprovider-target",
      "Namespace": "TestProvider",
      "Config": {
        "Type": "TestProvider",
        "Region": "us-east-1"
      }
    }
  ],
  "Stacks": [
    {
      "Label": "dns-stack",
      "Description": "DNS infrastructure stack"
    }
  ],
  "Resources": [
    {
      "Label": "my-zone",
