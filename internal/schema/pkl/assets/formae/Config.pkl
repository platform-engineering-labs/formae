open module formae.Config

typealias Port = Int(this >= 0 && this <= 65535)

typealias DatastoreType = "sqlite" | "postgres" | "auroradataapi"

class ServerConfig {
    nodename: String = "formae"

    hostname: String = "localhost"

    port: Port = 49684

    ergoPort: Port = 0

    registrarPort: Port = 4499

    secret: String = "secret"

    observerPort: Port = 0

    tlsCert: String?
    tlsKey: String?
}

class DatastoreConfig {
    datastoreType: DatastoreType = "sqlite"

    sqlite: SqliteConfig = new SqliteConfig{}

    postgres: PostgresConfig = new PostgresConfig{}

    auroraDataAPI: AuroraDataAPIConfig = new AuroraDataAPIConfig{}
}

class SqliteConfig {
    filePath: String = "~/.pel/formae/data/formae.db"
}

class PostgresConfig {
    host: String = "localhost"

    port: Port = 5432

    user: String = "postgres"

    password: String = "admin"

    database: String = ""

    schema: String = ""

    connectionParams: String = ""
}

class AuroraDataAPIConfig {
    clusterArn: String = ""

    secretArn: String = ""

    database: String = ""

    region: String = ""
}

class RetryConfig {
    statusCheckInterval: Duration = 20.s

    maxRetries: Int = 9

    retryDelay: Duration = 10.s
}

class DiscoveryConfig {
    enabled: Boolean = true

    labelTagKeys: Listing<String> = new Listing<String> {
        "Name"
    }

    interval: Duration = 10.min

    resourceTypesToDiscover: Listing<String> = new Listing<String> { }
}

class SynchronizationConfig {
    enabled: Boolean = true

    interval: Duration = 5.min
}

class StackExpirerConfig {
    enabled: Boolean = true

    interval: Duration = 5.s
}

class Target {
    label: String

    namespace: String = config.type.toUpperCase()

    discoverable: Boolean = false

    hidden config: Dynamic(this.hasProperty("type"))
    Config: Dynamic = config.toMap().mapKeys((k, _) -> k.capitalize()).toDynamic()
}

class User {
    username: String
    password: String
}

typealias LogLevel = "debug" | "info" | "warn" | "error"

class LoggingConfig {
    filePath: String = "~/.pel/formae/log/formae.log"

    fileLogLevel: LogLevel = "debug"

    consoleLogLevel: LogLevel = "info"
}

class OTLPConfig {
    /// Whether to enable OTLP push export (for traces, metrics, and logs)
    enabled: Boolean = true

    endpoint: String = "http://localhost:4317"

    protocol: "grpc" | "http" = "grpc"

    insecure: Boolean = true

    /// Metric temporality: "delta" (OTel-native, default) or "cumulative" (for Prometheus/Mimir without delta support)
    temporality: "delta" | "cumulative" = "delta"
}

class PrometheusConfig {
    /// Whether to expose a /metrics endpoint for Prometheus scraping
    enabled: Boolean = true
}

class OTelConfig {
    enabled: Boolean = false

    serviceName: String = "formae-agent"

    otlp: OTLPConfig = new OTLPConfig{}

    prometheus: PrometheusConfig = new PrometheusConfig{}
}

class TailscaleConfig {
    tls: Boolean = false
    authKey: String
    hostname: String?
    advertiseTags: Listing<String>?
}

class NetworkConfig {
    type: String
    tailscale: TailscaleConfig?
}

class RateLimitConfig {
    scope: String = "Namespace"
    maxRequestsPerSecondForNamespace: Int = 10
}

class LabelConfig {
    defaultQuery: String?
    resourceOverrides: Mapping<String, String>?
}

class FilterCondition {
    propertyPath: String
    propertyValue: String?
}

class MatchFilter {
    resourceTypes: Listing<String>
    conditions: Listing<FilterCondition>
}

open class BaseResourcePluginConfig {
    type: String
    enabled: Boolean = true
    rateLimit: RateLimitConfig?
    labelConfig: LabelConfig?
    discoveryFilters: Listing<MatchFilter>?
    resourceTypesToDiscover: Listing<String>?
    retry: RetryConfig?
}

open class BaseAgentAuthConfig {
    type: String
}

open class BaseCliAuthConfig {
    type: String
}

class AgentConfig {
    server: ServerConfig = new ServerConfig{}

    datastore: DatastoreConfig = new DatastoreConfig{}

    retry: RetryConfig = new RetryConfig{}

    synchronization: SynchronizationConfig = new SynchronizationConfig{}

    discovery: DiscoveryConfig = new DiscoveryConfig{}

    logging: LoggingConfig = new LoggingConfig{}

    oTel: OTelConfig = new OTelConfig{}

    stackExpirer: StackExpirerConfig = new StackExpirerConfig{}

    auth: (BaseAgentAuthConfig|Dynamic)?

    resourcePlugins: Listing<BaseResourcePluginConfig>(
        this.toList().map((it) -> it.type).isDistinct
    )?
}

class ApiConfig {
    url: String = "http://localhost"

    port: Port = 49684
}

class Repository {
  /// Orbital repository URI (optionally with #channel fragment).
  uri: Uri

  /// Discriminator: "binary" for the formae binary / tooling repo;
  /// "formae-plugin" for a plugin repo consulted by `formae plugin *`.
  type: "binary"|"formae-plugin"
}

class ArtifactConfig {
  @Deprecated { message = "Use artifacts.repositories instead" }
  url: Uri = "https://hub.platform.engineering/repos/platform.engineering/pel#stable"

  @Deprecated { message = "Use repository-specific credentials" }
  username: String?

  @Deprecated { message = "Use repository-specific credentials" }
  password: String?

  /// List of orbital repositories to consult for binary and plugin packages.
  repositories: Listing<Repository> = new {
    new {
      uri  = "https://hub.platform.engineering/repos/platform.engineering/pel#stable"
      type = "binary"
    }
    new {
      uri  = "https://hub.platform.engineering/repos/platform.engineering/community#stable"
      type = "formae-plugin"
    }
  }
}

class CliConfig {
    api: ApiConfig

    disableUsageReporting: Boolean = false

    auth: (BaseCliAuthConfig|Dynamic)?
}

/// Deprecated: use top-level pluginDir, network, and agent.auth / cli.auth instead.
class PluginConfig {
    pluginDir: String = "~/.pel/formae/plugins"

    hidden authentication: Dynamic?(
            if (this != null)
                this.hasProperty("type")
            else
                true
        )
    Authentication: Dynamic? =
        if (authentication != null)
            authentication
        else
            null

    hidden network: Dynamic?(
        if (this != null)
            this.hasProperty("type")
        else
            true
    )
    Network: Dynamic? =
        if (network != null)
            network
        else
            null
}

agent: AgentConfig = new AgentConfig{}

artifacts: ArtifactConfig = new ArtifactConfig{}

cli: CliConfig = new CliConfig{}

network: NetworkConfig?

pluginDir: String = "~/.pel/formae/plugins"

/// Deprecated: use top-level pluginDir, network, and agent.auth / cli.auth instead.
plugins: PluginConfig?