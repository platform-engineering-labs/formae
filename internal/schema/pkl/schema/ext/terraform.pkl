/// Read Terraform .tfvars files as Dynamic objects.
///
/// Example usage:
/// ```
/// import "@formae/ext/terraform.pkl"
///
/// local myVars = Terraform.readTFVars("my.tfvars")
/// region = myVars.region
/// ```
module Terraform

import "pkl:json"

/// Read a .tfvars file and return its values as a Dynamic.
///
/// The path is relative to the calling PKL module.
/// Only HCL-format .tfvars files are supported (not .tfvars.json).
/// Only literal values are supported (no variable references or function calls).
function readTFVars(path: String): Dynamic =
  let (result = new json.Parser{}.parse(read("tfvars:\(path)")))
    result
